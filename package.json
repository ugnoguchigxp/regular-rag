{
  "name": "regular-rag",
  "version": "0.0.1",
  "description": "Hono-first Artifact RAG app with Markdown knowledge ingestion, hybrid retrieval, and citations.",
  "type": "module",
  "author": "y.noguchi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y-noguchi/regular-rag.git"
  },
  "bugs": {
    "url": "https://github.com/y-noguchi/regular-rag/issues"
  },
  "homepage": "https://github.com/y-noguchi/regular-rag#readme",
  "keywords": [
    "rag",
    "llm",
    "knowledge-graph",
    "postgresql",
    "pgvector",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "start": "bun run src/app/server.ts",
    "import:markdown": "bun run src/cli/import-markdown.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/cli/migrate.ts",
    "db:migrate:drizzle": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src web",
    "format": "biome format --write src web",
    "format:check": "biome format src web",
    "build:server": "tsup",
    "build:web": "vite build",
    "build": "tsup && vite build",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run test && bun run build",
    "prepublishOnly": "npm run build:server"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.3",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jsdom": "^26.0.0",
    "lucide-react": "^1.16.0",
    "markdown-wysiwyg-editor": "^0.3.7",
    "mermaid": "^11.15.0",
    "pg": "^8.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@hono/vite-dev-server": "^0.25.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.10",
    "hono": "^4.11.9",
    "tailwindcss": "^4.3.0",
    "terser": "^5.46.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.0.18"
  }
}
