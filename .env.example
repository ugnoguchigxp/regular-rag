# App secret
JWT_SECRET=regular-rag-dev-jwt-secret-change-this-for-production

# Runtime origin / protocol mode
# HTTP POC: APP_URL=http://products.dev.gxp.jp, AUTH_COOKIE_SECURE=false, SECURITY_HEADERS_MODE=http
# HTTPS: APP_URL=https://products.dev.gxp.jp, AUTH_COOKIE_SECURE=true, SECURITY_HEADERS_MODE=https
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
AUTH_COOKIE_SECURE=false
SECURITY_HEADERS_MODE=auto

# Wiki storage
# local: use ./wiki-knowledge directly
# azure-blob: sync Azure Blob files into local wiki-knowledge before reading/indexing
WIKI_STORAGE_BACKEND=local
AZURE_STORAGE_CONNECTION_STRING=
WIKI_BLOB_CONTAINER=wiki-knowledge
WIKI_BLOB_PREFIX=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-4-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# OpenAI Responses API (optional direct provider)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Web Search API keys (optional)
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=
