# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/regular_rag
REGULAR_RAG_CONTENT_ROOT=./wiki-knowledge

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-5-4-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small
# Legacy chat/embedding provider 向け
AZURE_OPENAI_API_VERSION=2024-06-01

# Authentication
JWT_SECRET=regular-rag-dev-jwt-secret-change-this-for-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
# Optional bootstrap (runs only when users table is empty)
REGULAR_RAG_BOOTSTRAP_ADMIN_EMAIL=
REGULAR_RAG_BOOTSTRAP_ADMIN_PASSWORD=
REGULAR_RAG_BOOTSTRAP_ADMIN_NAME=

# Web Search (optional; Exa is the default provider)
WEB_SEARCH_PROVIDER=exa
EXA_API_KEY=YOUR_EXA_API_KEY
EXA_SEARCH_BASE_URL=https://api.exa.ai

# Brave Search (optional fallback; set WEB_SEARCH_PROVIDER=brave or auto)
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_SEARCH_API_KEY

# Agentic Search Responses API
# Option A) OpenAI: set OPENAI_API_KEY (+ optional OPENAI_BASE_URL)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
# Responses API で明示指定したい場合のみ設定（Azure /openai/v1 では通常は空）
OPENAI_API_VERSION=
# Option B) Azure OpenAI: if OPENAI_API_KEY is empty, AZURE_OPENAI_API_KEY is used.
# In that case, OPENAI_BASE_URL is auto-derived from AZURE_OPENAI_ENDPOINT as /openai/v1.
# Agentic Search uses AZURE_OPENAI_DEPLOYMENT as the model/deployment name.
# Agentic Search limits/debug defaults live in src/modules/agentic-search/constants.ts.
